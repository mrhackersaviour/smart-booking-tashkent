# Smart Booking Tashkent - Environment Configuration

# ===================
# Backend Configuration
# ===================

# Node environment (development, production, test)
NODE_ENV=production

# Server port
PORT=5000

# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ===================
# AI Configuration
# ===================

# Anthropic API Key for Claude AI
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===================
# Payment Configuration
# ===================

# Stripe Keys
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===================
# Database Configuration
# ===================

# SQLite database file path (relative to backend)
DATABASE_PATH=./data/smart_booking.db

# ===================
# Logging Configuration
# ===================

# Log level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# ===================
# Rate Limiting
# ===================

# Max requests per 15 minutes
RATE_LIMIT_MAX=100
